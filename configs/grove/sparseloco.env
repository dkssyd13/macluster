# macluster 2-Mac (grove) run config -- SparseLoCo. Sourced by scripts/grove_run.sh.
# Use the SAME file on both Macs (identical bytes -> no config-consensus abort).
# NOTE: on grove, comm_bytes logs the compact 8*k payload, but the measured
# sync_s reflects a DENSE all_sum transfer (see docs/PHASE7_TODO.md decisions).
MACLUSTER_TASK=cifar10
MACLUSTER_MODEL=resnet20
MACLUSTER_ALGORITHM=sparseloco
MACLUSTER_MAX_STEPS=500
MACLUSTER_H=20
MACLUSTER_K_FRAC=0.02
MACLUSTER_OUTER_LR=1.0
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.001
MACLUSTER_LINK=wifi
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=macluster
N=2
