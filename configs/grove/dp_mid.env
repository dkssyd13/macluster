# Phase DP_MID -- the DATA-PARALLEL half of the apples-to-apples DP-vs-MP
# head-to-head. gpt2_untied (~163M) FULLY REPLICATED on each Mac (one model per
# rank), aggregated via DiLoCo (low-comm: sync every H=20 local steps) over real
# grove.all_sum. Pair it with mp_mid.env (SAME model, model-parallel split).
# Both train the IDENTICAL untied-head architecture on the SAME data budget
# (MAX_STEPS*N*BATCH = 200*2*8 = 3200 samples), so the comparison is like-for-like.
#
# gpt2_untied's fp32 Adam state is ~2.6GB -> a full replica fits BOTH Macs (incl.
# the 24GB one), which is why DP is possible here (unlike gpt3b). To get other DP
# points, copy this file and change MACLUSTER_ALGORITHM to dense / sparseloco /
# adaptive (one line); each is a separate 2-Mac run.
# Sourced by scripts/run_mac_48gb.sh / run_mac_24gb.sh. SAME bytes on both Macs.
MACLUSTER_TASK=wikitext
MACLUSTER_MODEL=gpt2_untied      # same untied-head model mp_mid.env splits across stages
MACLUSTER_PARALLELISM=data
MACLUSTER_ALGORITHM=diloco       # low-comm DP baseline (dense|sparseloco|adaptive also valid)
MACLUSTER_MAX_STEPS=200          # per-replica local steps -> 200*2*8 = 3200 samples (matches mp_mid)
MACLUSTER_H=20
MACLUSTER_OUTER_LR=0.7
MACLUSTER_BATCH_SIZE=8
MACLUSTER_SEQ_LEN=128
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.0003
MACLUSTER_LINK=wifi              # operator-declared link label (measured, not emulated)
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=mac_dp                   # unique per phase -> no cluster-name reuse
N=2
