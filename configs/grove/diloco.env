# macluster 2-Mac (grove) run config -- DiLoCo. Sourced by scripts/grove_run.sh.
# Use the SAME file on both Macs (identical bytes -> no config-consensus abort).
MACLUSTER_TASK=cifar10
MACLUSTER_MODEL=resnet20
MACLUSTER_ALGORITHM=diloco
MACLUSTER_MAX_STEPS=500        # equal total-local-step budget (fair vs dense H=1)
MACLUSTER_H=20
MACLUSTER_OUTER_LR=0.7
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.001
MACLUSTER_LINK=wifi            # operator-declared link condition label (measured, not emulated)
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

# grove launch (consumed by grove_run.sh, not by macluster):
CLUSTER=macluster
N=2
