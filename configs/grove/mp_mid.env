# Phase MP_MID -- the MODEL-PARALLEL half of the apples-to-apples DP-vs-MP
# head-to-head. gpt2_untied (~163M) split across the 2 Macs over real send/recv.
# Pair it with dp_mid.env (SAME model, data-parallel) for the comparison: both
# train the IDENTICAL untied-head architecture on the SAME data budget
# (MAX_STEPS*N_MICRO*BATCH = 100*4*8 = 3200 samples), so wall-clock / comm bytes /
# peak memory / convergence are compared like-for-like.
# Sourced by scripts/run_mac_48gb.sh / run_mac_24gb.sh. SAME bytes on both Macs.
MACLUSTER_TASK=wikitext
MACLUSTER_MODEL=gpt2_untied      # same untied-head model dp_mid.env trains data-parallel
MACLUSTER_PARALLELISM=pipeline
MACLUSTER_STAGE_MEM_GB=48,24     # memory-aware cut: rank0(48GB)=larger stage, rank1(24GB)=smaller
MACLUSTER_N_MICRO=4
MACLUSTER_MAX_STEPS=100          # optimizer steps -> 100*4*8 = 3200 samples (matches dp_mid)
MACLUSTER_BATCH_SIZE=8
MACLUSTER_SEQ_LEN=128
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.0003
MACLUSTER_LINK=wifi              # operator-declared link label (measured, not emulated)
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=mac_mp                   # unique per phase -> no cluster-name reuse
N=2
