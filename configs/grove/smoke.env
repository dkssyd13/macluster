# macluster grove SMOKE config -- synthetic data, tiny run, no second Mac needed.
#   single machine:  ./scripts/grove_run.sh smoke
#   real 2-Mac pair: ./scripts/grove_run.sh start configs/grove/smoke.env  (mac-A)
#                    ./scripts/grove_run.sh join  configs/grove/smoke.env  (mac-B)
MACLUSTER_SYNTHETIC=1
MACLUSTER_TASK=cifar10
MACLUSTER_MODEL=resnet20
MACLUSTER_ALGORITHM=dense
MACLUSTER_ROUNDS=3
MACLUSTER_EVAL_EVERY=1
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs/smoke      # keep throwaway smoke runs out of the results namespace

CLUSTER=macluster-smoke
N=2
