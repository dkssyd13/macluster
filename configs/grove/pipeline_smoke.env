# Phase SMOKE -- 2-Mac connectivity + seam check (synthetic, instant, no download).
# Sourced by scripts/run_mac_48gb.sh / run_mac_24gb.sh. SAME bytes on both Macs.
MACLUSTER_SYNTHETIC=1
MACLUSTER_TASK=shakespeare
MACLUSTER_MODEL=chargpt
MACLUSTER_PARALLELISM=pipeline
MACLUSTER_CUT=2                # chargpt has 4 blocks -> 2 stages (blocks[:2] | blocks[2:])
MACLUSTER_N_MICRO=2
MACLUSTER_ROUNDS=3
MACLUSTER_BATCH_SIZE=8
MACLUSTER_SEQ_LEN=32
MACLUSTER_EVAL_EVERY=1
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=mac_smoke             # unique per phase -> no cluster-name reuse across phases
N=2
