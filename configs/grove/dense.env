# macluster 2-Mac (grove) run config -- Dense (sync every step). Comm-heavy
# baseline the low-comm methods are measured against. Sourced by grove_run.sh.
# Use the SAME file on both Macs. Dense H=1 syncs 500x over the network at this
# budget -- expect it to be the slowest wall-clock, which is the point.
MACLUSTER_TASK=cifar10
MACLUSTER_MODEL=resnet20
MACLUSTER_ALGORITHM=dense
MACLUSTER_MAX_STEPS=500
MACLUSTER_H=1
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.001
MACLUSTER_LINK=wifi
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=macluster
N=2
