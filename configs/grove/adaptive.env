# macluster 2-Mac (grove) run config -- AdaptiveSync (axis-3, novel contribution).
# Sourced by scripts/grove_run.sh. Use the SAME file on both Macs.
# The controller now retunes H / k_frac from the REAL measured sync_s/compute_s
# ratio each round -- the whole point of the 2-Mac run. Try MACLUSTER_LINK=awdl
# (AirDrop-only, no shared Wi-Fi) to exercise the degraded-link k_frac response.
MACLUSTER_TASK=cifar10
MACLUSTER_MODEL=resnet20
MACLUSTER_ALGORITHM=adaptive
MACLUSTER_MAX_STEPS=500
MACLUSTER_H=20
MACLUSTER_K_FRAC=0.02
MACLUSTER_OUTER_LR=1.0
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.001
MACLUSTER_LINK=wifi
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=macluster
N=2
