# Phase XL -- gpt_xl (~1.6B) over real wikitext. Both Macs comfortably fit their
# stage (state ~17.5GB on 48GB rank0 / ~8.7GB on 24GB rank1). A model >1B that DP
# could also run, so it doubles as the safe pre-flight before the gpt3b headline.
# Sourced by scripts/run_mac_48gb.sh / run_mac_24gb.sh. SAME bytes on both Macs.
MACLUSTER_TASK=wikitext
MACLUSTER_MODEL=gpt_xl
MACLUSTER_PARALLELISM=pipeline
MACLUSTER_STAGE_MEM_GB=48,24   # memory-aware cut: rank0(48GB)=larger stage, rank1(24GB)=smaller
MACLUSTER_N_MICRO=4
MACLUSTER_MAX_STEPS=30         # bounded run (optimizer steps)
MACLUSTER_BATCH_SIZE=8
MACLUSTER_SEQ_LEN=128
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.0003
MACLUSTER_LINK=wifi            # operator-declared link label (measured, not emulated)
MACLUSTER_EVAL_EVERY=0          # disable fragile split eval over Wi-Fi; system metrics are headline
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

CLUSTER=mac_xl
N=2
