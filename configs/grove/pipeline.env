# macluster 2-Mac (grove) run config -- PIPELINE (model) parallelism, Phase 8.
# Sourced by scripts/grove_run.sh. Use the SAME file on both Macs (identical
# bytes -> no config-consensus abort). One STAGE per Mac (rank == stage):
#   N == number of stages == len(cut)+1 == world_size.
#
#   mac-A (launcher):  ./scripts/grove_run.sh start configs/grove/pipeline.env
#   mac-B (joiner):    ./scripts/grove_run.sh join  configs/grove/pipeline.env

MACLUSTER_TASK=wikitext         # GPT (text) task; pipeline is GPT-only
MACLUSTER_MODEL=gpt2            # gpt2 (~163M, fits one node: validates the seam)
                               # scale up for the headline: gpt_xl (~1.6B) / gpt3b (~2.7B)
MACLUSTER_PARALLELISM=pipeline
MACLUSTER_CUT=8                # explicit block cut -> 2 stages: blocks[:8] | blocks[8:]
                               # (or drop CUT and set STAGE_MEM_GB for an auto memory-aware cut)
# MACLUSTER_STAGE_MEM_GB=48,24 # per-Mac RAM budget; auto-sizes the cut (more blocks on mac-A)
MACLUSTER_N_MICRO=4            # micro-batches per optimizer step (1F1B; warmup=1 for 2 stages)
MACLUSTER_ROUNDS=50           # optimizer steps (use MACLUSTER_MAX_STEPS for a step budget)
MACLUSTER_BATCH_SIZE=16
MACLUSTER_SEQ_LEN=128
MACLUSTER_INNER_OPT=adam
MACLUSTER_INNER_LR=0.0003
MACLUSTER_LINK=wifi            # operator-declared link label (measured, not emulated)
MACLUSTER_EVAL_EVERY=5
MACLUSTER_SEED=0
MACLUSTER_RUNS_ROOT=runs

# grove launch (consumed by grove_run.sh, not by macluster):
CLUSTER=macluster
N=2                            # MUST equal the stage count (len(CUT)+1)
